{
  "name": "portal-aframe-ref",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf ../public && mkdir -p ../public",
    "build": "npm run clean && webpack --mode=production --config config/webpack.config.js",
    "build:dev": "npm run clean && webpack --mode=development --config config/webpack.config.js",
    "server": "webpack-dev-server --mode=development --config config/webpack.config.js"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/parser": "^7.23.9",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/preset-env": "^7.23.9",
    "@babel/runtime": "^7.28.4",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.5",
    "style-loader": "^4.0.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.2"
  }
}
