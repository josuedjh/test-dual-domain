---
// Import HTML files as raw strings (works in Amplify)
import indexEu from './index.eu.html?raw';
import indexEs from './index.es.html?raw';

const host = Astro.request.headers.get('host') || 'unknown';

const hostConfig: Record<string, 'eu' | 'es'> = {
  // Desarrollo
  'topoberriagertuago.topo.localhost:4321': 'eu',
  'nuevotopomascerca.topo.localhost:4321': 'es',
  // Producción
  'new.yapamarket.com': 'eu',
  'nuevo.yapamarket.com': 'es',
};

const lang = hostConfig[host] || 'es';
const htmlContent = lang === 'eu' ? indexEu : indexEs;

return new Response(htmlContent, {
  status: 200,
  headers: { 'Content-Type': 'text/html; charset=utf-8' }
});
---