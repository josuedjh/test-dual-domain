---
// Detectar el dominio del host desde el header de la solicitud
const host = Astro.request.headers.get('host') || 'unknown';

// Determinar el idioma basado en el dominio
let language = 'EN';
let languageCode = 'en';
let pageTitle = 'YapaMarket / EN';
let welcomeMessage = 'Welcome to YapaMarket';
let description = 'Multi-language and multi-domain marketplace powered by Astro SSR';

if (host.includes('nuevo.yapamarket.com')) {
  language = 'ES';
  languageCode = 'es';
  pageTitle = 'YapaMarket / ES';
  welcomeMessage = 'Bienvenido a YapaMarket';
  description = 'Mercado multilenguaje y multidominio impulsado por Astro SSR';
} else if (host.includes('new.yapamarket.com')) {
  language = 'EN';
  languageCode = 'en';
  pageTitle = 'YapaMarket / EN';
  welcomeMessage = 'Welcome to YapaMarket';
  description = 'Multi-language and multi-domain marketplace powered by Astro SSR';
}
---

<!DOCTYPE html>
<html lang={languageCode}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen,
          Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
      }

      .container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        padding: 40px;
        max-width: 600px;
        width: 100%;
        text-align: center;
      }

      h1 {
        color: #333;
        font-size: 2.5em;
        margin-bottom: 10px;
        font-weight: 700;
      }

      .language-badge {
        display: inline-block;
        background: #667eea;
        color: white;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.9em;
        margin-bottom: 20px;
        font-weight: 600;
      }

      p {
        color: #666;
        font-size: 1.1em;
        margin-bottom: 30px;
        line-height: 1.6;
      }

      .info-box {
        background: #f5f5f5;
        border-left: 4px solid #667eea;
        padding: 15px 20px;
        margin: 20px 0;
        text-align: left;
        border-radius: 4px;
      }

      .info-box h3 {
        color: #333;
        margin-bottom: 8px;
        font-size: 1em;
      }

      .info-box p {
        color: #666;
        font-size: 0.95em;
        margin: 0;
      }

      .links {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-top: 30px;
        flex-wrap: wrap;
      }

      a {
        display: inline-block;
        padding: 10px 20px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
      }

      .btn-status {
        background: #667eea;
        color: white;
      }

      .btn-status:hover {
        background: #5568d3;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
      }

      .btn-domain {
        background: #f0f0f0;
        color: #333;
        border: 2px solid #667eea;
      }

      .btn-domain:hover {
        background: #667eea;
        color: white;
        transform: translateY(-2px);
      }

      .host-display {
        color: #667eea;
        font-family: 'Courier New', monospace;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>YapaMarket</h1>
      <span class="language-badge">{language}</span>
      <p>{welcomeMessage}</p>

      <div class="info-box">
        <h3>{language === 'EN' ? 'Server Information' : 'Información del Servidor'}</h3>
        <p>
          {language === 'EN' ? 'Domain: ' : 'Dominio: '}<span class="host-display">{host}</span>
        </p>
      </div>

      <div class="info-box">
        <h3>{language === 'EN' ? 'SSR Status' : 'Estado SSR'}</h3>
        <p>
          {
            language === 'EN'
              ? '✓ Server-Side Rendering is active on AWS Amplify'
              : '✓ Server-Side Rendering activo en AWS Amplify'
          }
        </p>
      </div>

      <div class="links">
        <a href="/status" class="btn-status">
          {language === 'EN' ? 'View Status' : 'Ver Estado'}
        </a>
      </div>
    </div>
  </body>
</html>
