---
import { readFileSync } from 'fs';
import { fileURLToPath } from 'url';
import { dirname } from 'path';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

const host = Astro.request.headers.get('host') || 'unknown';

const hostConfig: Record<string, string> = {
  'topoberriagertuago.topo.localhost:4321': 'index.eu.html',
  'nuevotopomascerca.topo.localhost:4321': 'index.es.html',
};

const htmlFile = hostConfig[host] || 'index.es.html';
const filePath = `${__dirname}/${htmlFile}`;
const htmlContent = readFileSync(filePath, 'utf-8');

return new Response(htmlContent, {
  status: 200,
  headers: { 'Content-Type': 'text/html; charset=utf-8' }
});
---


